#!/bin/sh

# Check if /bin/s6-svscan exists, if not create symlink to /usr/bin/s6-svscan
if [ ! -e /bin/s6-svscan ] && [ -e /usr/bin/s6-svscan ]; then
    ln -s /usr/bin/s6-svscan /bin/s6-svscan
fi

addgroup -S <%= name %> 2>/dev/null
adduser -S -D -H -h /var/lib/<%= name %> -s /sbin/nologin -G <%= name %> -g <%= name %> <%= name %> 2>/dev/null
addgroup <%= name %> 2>/dev/null

exit 0
